# Stock Data APIs
FINNHUB_API_KEY=your_key_here
SECTORS_API_KEY=your_key_here

# AI
GEMINI_API_KEY=your_key_here

# Authentication
JWT_SECRET=your_random_secret_key_here
JWT_REFRESH_SECRET=your_random_refresh_secret_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_COOKIE_NAME=bot_saham_session

# Domain induk untuk sharing cookie antar subdomain (opsional)
# Kosongkan untuk localhost, set .domain.com untuk production subdomain
COOKIE_DOMAIN=

# Server
PORT=3001

# Origins yang diizinkan CORS (pisahkan dengan koma jika lebih dari satu)
# Tambahkan semua URL dari mana client akan mengakses API ini
CLIENT_URLS=http://localhost:5173,http://localhost,http://127.0.0.1

# Base path untuk client (digunakan saat build Vite)
# Jika di-serve dari root      : VITE_BASE_PATH=/
# Jika di-serve dari subfolder : VITE_BASE_PATH=/bot-saham-client/
VITE_BASE_PATH=/

# URL endpoint API backend yang diakses oleh Client
# Jika lokal/dev (default): VITE_API_URL=http://localhost:3001
# Jika production vhost   : VITE_API_URL=http://api.botsaham.local
VITE_API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/bot_saham

# ──────────────────────────────────────
# Deployment (digunakan oleh deploy.sh)
# ──────────────────────────────────────

# Path tujuan deploy hasil build client (client/dist → DEPLOY_PATH)
# Contoh production : /var/www/bot-saham
# Contoh lokal      : /Users/namauser/Sites/bot-saham/client/dist
DEPLOY_PATH=/var/www/bot-saham

# Jalankan migrasi database saat deploy? (true/false)
RUN_MIGRATE=true

# Jalankan seed database saat deploy? Hanya untuk setup pertama kali (true/false)
RUN_SEED=false
